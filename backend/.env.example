# Environment variables for backend
NODE_ENV=development
PORT=5000

# Database Connection
DATABASE_URL="postgresql://user:password@localhost:5432/restaurant_db"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRY=24h
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production-12345
REFRESH_TOKEN_EXPIRY=7d

# Server Configuration
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# WebSocket Configuration
WS_PORT=5001
WS_CORS_ORIGIN=http://localhost:3000

# Email Configuration (for future use)
EMAIL_SERVICE=gmail
EMAIL_USER=noreply@restaurant.com
EMAIL_PASSWORD=your-email-password

# S3/Cloud Storage (for image uploads)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=restaurant-uploads

# Stripe/Payment Configuration (for future use)
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLIC_KEY=pk_test_your_key

# Logging
LOG_LEVEL=debug
