// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  ADMIN
  MANAGER
  WAITER
  KITCHEN
  DELIVERY_STAFF
  CUSTOMER
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE
  CHEQUE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

// ============================================================================
// CORE ENTITIES
// ============================================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      UserRole @default(WAITER)
  
  // Profile
  avatar    String?
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  
  // Relationships
  createdOrders   Order[]      @relation("CreatedBy")
  updatedOrders   Order[]      @relation("UpdatedBy")
  payments        Payment[]
  timeline        OrderTimeline[]
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([isActive])
}

// ============================================================================
// MENU MANAGEMENT
// ============================================================================

model MenuCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  image       String?
  position    Int      @default(0)
  isActive    Boolean  @default(true)
  
  // Relationships
  items       MenuItem[]
  
  // Metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([position])
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @default(0)
  image       String?
  
  // Category
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  // Availability
  isAvailable Boolean  @default(true)
  preparationTime Int @default(15) // in minutes
  
  // Variants (sizes, extras, etc.)
  variants    MenuVariant[]
  
  // Orders containing this item
  orderItems  OrderItem[]
  
  // Metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@index([isAvailable])
  @@index([name])
}

model MenuVariant {
  id          String   @id @default(cuid())
  name        String   // e.g., "Size", "Extra"
  value       String   // e.g., "Large", "Extra Cheese"
  priceModifier Decimal @default(0)
  
  // Relationship
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  
  // Order items variants
  orderItemVariants OrderItemVariant[]
  
  // Metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([menuItemId, name, value])
  @@index([menuItemId])
}

// ============================================================================
// TABLE MANAGEMENT
// ============================================================================

model Table {
  id          String   @id @default(cuid())
  tableNumber Int      @unique
  capacity    Int
  location    String?  // e.g., "Window", "Corner"
  status      TableStatus @default(AVAILABLE)
  
  // QR Code for customer ordering
  qrCode      String?
  
  // Current order (if occupied)
  currentOrderId String? @unique
  currentOrder   Order?  @relation("TableCurrentOrder")
  
  // Metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([currentOrderId])
}

// ============================================================================
// ORDER MANAGEMENT
// ============================================================================

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique // Friendly order number like "ORD-001"
  
  // Order Type & Status
  type            OrderType   @default(DINE_IN)
  status          OrderStatus @default(PENDING)
  
  // Table (for dine-in)
  tableId         String? @unique
  table           Table?  @relation("TableCurrentOrder", fields: [tableId], references: [id])
  
  // Customer info (for takeaway/delivery)
  customerName    String?
  customerPhone   String?
  customerEmail   String?
  deliveryAddress String?
  
  // Items
  items           OrderItem[]
  
  // Calculations
  subtotal        Decimal @default(0)
  taxAmount       Decimal @default(0)
  serviceCharge   Decimal @default(0)
  totalAmount     Decimal @default(0)
  
  // Special instructions
  specialInstructions String?
  
  // Relationships
  createdByUserId String
  createdByUser   User        @relation("CreatedBy", fields: [createdByUserId], references: [id])
  
  updatedByUserId String?
  updatedByUser   User?       @relation("UpdatedBy", fields: [updatedByUserId], references: [id])
  
  payment         Payment?
  timeline        OrderTimeline[]
  
  // Timing
  estimatedReadyTime DateTime?
  actualReadyTime    DateTime?
  servedAt           DateTime?
  
  // Metadata
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([orderNumber])
  @@index([status])
  @@index([tableId])
  @@index([type])
  @@index([createdAt])
  @@index([createdByUserId])
}

model OrderItem {
  id              String  @id @default(cuid())
  quantity        Int
  price           Decimal @default(0)
  specialNotes    String?
  
  // Relationships
  orderId         String
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  menuItemId      String
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id])
  
  // Variants
  variants        OrderItemVariant[]
  
  // Metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orderId])
  @@index([menuItemId])
}

model OrderItemVariant {
  id              String  @id @default(cuid())
  
  // Relationships
  orderItemId     String
  orderItem       OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  
  variantId       String
  variant         MenuVariant @relation(fields: [variantId], references: [id])
  
  // Metadata
  createdAt       DateTime @default(now())

  @@unique([orderItemId, variantId])
  @@index([orderItemId])
}

// ============================================================================
// ORDER TIMELINE (Audit Trail)
// ============================================================================

model OrderTimeline {
  id          String  @id @default(cuid())
  
  // Order reference
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  // Status change
  oldStatus   OrderStatus?
  newStatus   OrderStatus
  
  // Who changed it
  changedByUserId String
  changedByUser   User @relation(fields: [changedByUserId], references: [id])
  
  // Notes
  notes       String?
  
  // Metadata
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([newStatus])
}

// ============================================================================
// PAYMENT
// ============================================================================

model Payment {
  id              String  @id @default(cuid())
  
  // Order reference
  orderId         String  @unique
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  // Payment info
  amount          Decimal @default(0)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  
  // Transaction reference
  transactionId   String?
  receiptNumber   String?
  
  // User who processed
  processedByUserId String
  processedByUser   User @relation(fields: [processedByUserId], references: [id])
  
  // Refund info
  refundedAmount  Decimal @default(0)
  refundReason    String?
  
  // Metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================================
// SETTINGS & CONFIGURATION
// ============================================================================

model RestaurantSettings {
  id              String  @id @default(cuid())
  
  // Restaurant Info
  restaurantName  String
  description     String?
  logo            String?
  favicon         String?
  
  // Timing
  operatingHours  String? // JSON format
  
  // Fees
  taxPercentage   Decimal @default(0)
  serviceChargePercentage Decimal @default(0)
  
  // Features
  enableDelivery  Boolean @default(false)
  enableTakeaway  Boolean @default(true)
  enableDineIn    Boolean @default(true)
  enableAdvanceOrder Boolean @default(false)
  
  // Kitchen settings
  kitchenSoundAlert Boolean @default(true)
  
  // Metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
